<ui:FluentWindow x:Class="AutoTool.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:panel="clr-namespace:AutoTool.Desktop.View"
        xmlns:converters="clr-namespace:AutoTool.Desktop.View.Converters"
        mc:Ignorable="d"
        Title="{Binding AutoToolTitle}"
        MinWidth="640" MinHeight="420"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        PreviewKeyDown="MainWindow_PreviewKeyDown"
        PreviewKeyUp="MainWindow_PreviewKeyUp">

    <ui:FluentWindow.Resources>
        <converters:InvertBooleanConverter x:Key="InvertBooleanConverter"/>
        <converters:RunningStatusConverter x:Key="RunningStatusConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>
    </ui:FluentWindow.Resources>

    <!-- キーボードショートカットの設定 -->
    <ui:FluentWindow.InputBindings>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveFileCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl+Shift" Command="{Binding SaveFileAsCommand}"/>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding OpenFileCommand}"/>
        <KeyBinding Key="Z" Modifiers="Ctrl" Command="{Binding UndoCommand}"/>
        <KeyBinding Key="Y" Modifiers="Ctrl" Command="{Binding RedoCommand}"/>
        <KeyBinding Key="Z" Modifiers="Ctrl+Shift" Command="{Binding RedoCommand}"/>
        <KeyBinding Key="C" Modifiers="Ctrl" Command="{Binding MacroPanelViewModel.ButtonPanelViewModel.CopyCommand}"/>
        <KeyBinding Key="V" Modifiers="Ctrl" Command="{Binding MacroPanelViewModel.ButtonPanelViewModel.PasteCommand}"/>
    </ui:FluentWindow.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- タイトルバー -->
        <ui:TitleBar Grid.Row="0" Title="{Binding AutoToolTitle}" ShowMinimize="True" ShowMaximize="True" ShowClose="True">
            <ui:TitleBar.Header>
                <StackPanel Orientation="Horizontal" Margin="8,0">
                    <ui:Button
                               Command="{Binding MacroPanelViewModel.ButtonPanelViewModel.RunCommand}"
                               Foreground="White"
                               Appearance="Primary"
                               Padding="8,2">
                        <ui:Button.Style>
                            <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                <Setter Property="Icon" Value="{ui:SymbolIcon Play24}"/>
                                <Setter Property="ToolTip" Value="実行"/>
                                <Setter Property="Appearance" Value="Primary"/>
                                <Setter Property="Background" Value="#10B981"/>
                                <Setter Property="BorderBrush" Value="#10B981"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Icon" Value="{ui:SymbolIcon Stop24}"/>
                                        <Setter Property="ToolTip" Value="停止"/>
                                        <Setter Property="Appearance" Value="Danger"/>
                                        <Setter Property="Background" Value="#EF4444"/>
                                        <Setter Property="BorderBrush" Value="#EF4444"/>
                                    </DataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsRunning}" Value="True"/>
                                            <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Background" Value="#DC2626"/>
                                        <Setter Property="BorderBrush" Value="#DC2626"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:Button.Style>
                    </ui:Button>
                    <Border Width="1" Background="{ui:ThemeResource ControlStrokeColorDefaultBrush}" Margin="8,8"/>
                    <ui:Button Icon="{ui:SymbolIcon Add24}"
                               ToolTip="コマンド追加"
                               Click="AddCommandButton_Click"
                               Foreground="White"
                               Background="#F59E0B"
                               BorderBrush="#F59E0B"
                               Appearance="Primary"
                               Padding="8,2"
                               IsEnabled="{Binding IsRunning, Converter={StaticResource InvertBooleanConverter}}"/>
                    <Border Width="1" Background="{ui:ThemeResource ControlStrokeColorDefaultBrush}" Margin="8,8"/>
                    <ui:Button Icon="{ui:SymbolIcon FolderOpen24}" 
                               ToolTip="開く (Ctrl+O)" 
                               Command="{Binding OpenFileCommand}"
                               Appearance="Transparent"
                               IsEnabled="{Binding IsRunning, Converter={StaticResource InvertBooleanConverter}}"/>
                    <ui:Button Icon="{ui:SymbolIcon Save24}" 
                               ToolTip="保存 (Ctrl+S)" 
                               Command="{Binding SaveFileCommand}"
                               Appearance="Transparent"/>
                    <ui:Button Icon="{ui:SymbolIcon Save24}"
                               ToolTip="名前を付けて保存 (Ctrl+Shift+S)"
                               Command="{Binding SaveFileAsCommand}"
                               Appearance="Transparent"/>
                    <Border Width="1" Background="{ui:ThemeResource ControlStrokeColorDefaultBrush}" Margin="8,8"/>
                    <ui:Button Icon="{ui:SymbolIcon ArrowUndo24}" 
                               ToolTip="{Binding CommandHistory.UndoDescription, StringFormat='元に戻す: {0}'}" 
                               Command="{Binding UndoCommand}"
                               Appearance="Transparent"/>
                    <ui:Button Icon="{ui:SymbolIcon ArrowRedo24}" 
                               ToolTip="{Binding CommandHistory.RedoDescription, StringFormat='やり直し: {0}'}" 
                               Command="{Binding RedoCommand}"
                               Appearance="Transparent"/>
                    <Border Width="1" Background="{ui:ThemeResource ControlStrokeColorDefaultBrush}" Margin="8,8"/>
                    <ui:Button Icon="{ui:SymbolIcon Copy24}"
                               ToolTip="コピー (Ctrl+C)"
                               Command="{Binding MacroPanelViewModel.ButtonPanelViewModel.CopyCommand}"
                               Appearance="Transparent"
                               IsEnabled="{Binding IsRunning, Converter={StaticResource InvertBooleanConverter}}"/>
                    <ui:Button Icon="{ui:SymbolIcon ClipboardPaste24}"
                               ToolTip="貼り付け (Ctrl+V)"
                               Command="{Binding MacroPanelViewModel.ButtonPanelViewModel.PasteCommand}"
                               Appearance="Transparent"
                               IsEnabled="{Binding IsRunning, Converter={StaticResource InvertBooleanConverter}}"/>
                    <Border Width="1" Background="{ui:ThemeResource ControlStrokeColorDefaultBrush}" Margin="8,8"/>
                    <ui:Button Icon="{ui:SymbolIcon DismissCircle24}"
                               ToolTip="すべてクリア"
                               Command="{Binding MacroPanelViewModel.ButtonPanelViewModel.ClearCommand}"
                               Appearance="Transparent"
                               IsEnabled="{Binding IsRunning, Converter={StaticResource InvertBooleanConverter}}"/>
                    <Border Width="1" Background="{ui:ThemeResource ControlStrokeColorDefaultBrush}" Margin="8,8"/>
                    <ui:Button Icon="{ui:SymbolIcon Settings24}"
                               ToolTip="設定"
                               Appearance="Transparent"
                               Click="SettingsButton_Click"/>
                    <Border Width="1" Background="{ui:ThemeResource ControlStrokeColorDefaultBrush}" Margin="8,8"/>
                    <ui:Button Icon="{ui:SymbolIcon Info24}"
                               ToolTip="バージョン情報"
                               Click="AboutButton_Click"
                               Appearance="Transparent"/>
                </StackPanel>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <!-- 拡張ツールバー -->
        <Border Grid.Row="1"
                Background="{ui:ThemeResource ControlFillColorDefaultBrush}"
                BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,6"
                Visibility="{Binding PluginQuickActions.Count, Converter={StaticResource CountToVisibilityConverter}}">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Left"
                           Text="プラグイン拡張"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"
                           FontSize="12"
                           Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                <ItemsControl ItemsSource="{Binding PluginQuickActions}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ui:Button Command="{Binding ExecuteCommand}"
                                       IsEnabled="{Binding IsEnabled}"
                                       ToolTip="{Binding EffectiveToolTip}"
                                       ToolTipService.ShowOnDisabled="True"
                                       Appearance="Secondary"
                                       Height="30"
                                       MinWidth="40"
                                       Padding="8,2"
                                       Margin="0,0,6,0">
                                <ui:Button.Icon>
                                    <ui:SymbolIcon Symbol="{Binding IconSymbol}"/>
                                </ui:Button.Icon>
                                <TextBlock Text="{Binding DisplayName}"
                                           Margin="4,0,0,0"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="180"/>
                            </ui:Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>

        <!-- メインコンテンツ -->
        <Grid Grid.Row="2" Margin="0">
            <panel:MacroPanel DataContext="{Binding MacroPanelViewModel}"/>
        </Grid>

        <!-- ステータスバー -->
        <Border Grid.Row="3"
                Background="{ui:ThemeResource ControlFillColorDefaultBrush}" 
                BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           Text="{Binding StatusMessage}" 
                           VerticalAlignment="Center"
                           Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0"
                            Visibility="{Binding CommandHistory.CanUndo, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ui:SymbolIcon Symbol="ArrowUndo24" FontSize="12" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding CommandHistory.UndoDescription}" 
                               Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                               FontSize="12"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="12,0,8,0">
                    <ui:Button Command="{Binding MacroPanelViewModel.ToggleFavoritePanelCommand}"
                               Content="☆"
                               ToolTip="お気に入りパネルの表示切替"
                               MinWidth="36"
                               Height="28"
                               Padding="8,2"
                               Margin="0,0,6,0">
                        <ui:Button.Style>
                            <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                <Setter Property="Appearance" Value="Secondary"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding MacroPanelViewModel.IsFavoritePanelOpen}" Value="True">
                                        <Setter Property="Appearance" Value="Primary"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:Button.Style>
                    </ui:Button>

                    <ui:Button Command="{Binding MacroPanelViewModel.ToggleLogPanelCommand}"
                               Content="ログ"
                               ToolTip="ログパネルの表示切替"
                               MinWidth="48"
                               Height="28"
                               Padding="10,2"
                               Margin="0,0,6,0">
                        <ui:Button.Style>
                            <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                <Setter Property="Appearance" Value="Secondary"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding MacroPanelViewModel.IsLogPanelOpen}" Value="True">
                                        <Setter Property="Appearance" Value="Primary"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:Button.Style>
                    </ui:Button>

                    <ui:Button Command="{Binding MacroPanelViewModel.ToggleVariablePanelCommand}"
                               Content="変数"
                               ToolTip="変数パネルの表示切替"
                               MinWidth="48"
                               Height="28"
                               Padding="10,2"
                               Margin="0,0,6,0">
                        <ui:Button.Style>
                            <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                <Setter Property="Appearance" Value="Secondary"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding MacroPanelViewModel.IsVariablePanelOpen}" Value="True">
                                        <Setter Property="Appearance" Value="Primary"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:Button.Style>
                    </ui:Button>

                    <ui:Button Command="{Binding MacroPanelViewModel.TogglePreflightPanelCommand}"
                               Content="診断"
                               ToolTip="実行前チェックパネルの表示切替"
                               MinWidth="48"
                               Height="28"
                               Padding="10,2">
                        <ui:Button.Style>
                            <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                <Setter Property="Appearance" Value="Secondary"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding MacroPanelViewModel.IsPreflightPanelOpen}" Value="True">
                                        <Setter Property="Appearance" Value="Primary"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:Button.Style>
                    </ui:Button>
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Margin="0,0,6,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#10B981"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Fill" Value="#F59E0B"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding IsRunning, Converter={StaticResource RunningStatusConverter}}"
                               Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                               FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
