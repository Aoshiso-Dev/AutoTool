<UserControl x:Class="AutoTool.Desktop.View.MacroPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:converters="clr-namespace:AutoTool.Desktop.View.Converters"
        xmlns:panels="clr-namespace:AutoTool.Desktop.Panels.View"
        mc:Ignorable="d">

    <UserControl.Resources>
        <converters:FavoritePanelWidthMultiConverter x:Key="FavoritePanelWidthMultiConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition>
                    <ColumnDefinition.Width>
                        <MultiBinding Converter="{StaticResource FavoritePanelWidthMultiConverter}" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged">
                            <Binding Path="IsFavoritePanelOpen" Mode="OneWay"/>
                            <Binding Path="FavoritePanelWidth" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged"/>
                        </MultiBinding>
                    </ColumnDefinition.Width>
                </ColumnDefinition>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="8,0,8,8" ClipToBounds="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Background="{ui:ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Grid.Row="0"
                        VerticalAlignment="Stretch"
                        HorizontalAlignment="Stretch">
                    <panels:ListPanel DataContext="{Binding ListPanelViewModel}"
                                      VerticalAlignment="Stretch"
                                      HorizontalAlignment="Stretch"/>
                </Border>

                <Border HorizontalAlignment="Stretch"
                        VerticalAlignment="Bottom"
                        MaxHeight="240"
                        Margin="0,0,0,0"
                        Panel.ZIndex="35">
                    <Border.RenderTransform>
                        <TranslateTransform Y="260"/>
                    </Border.RenderTransform>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Opacity" Value="0"/>
                            <Setter Property="IsHitTestVisible" Value="False"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPreflightPanelOpen}" Value="True">
                                    <Setter Property="IsHitTestVisible" Value="True"/>
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                 To="0"
                                                                 Duration="0:0:0.2">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                 To="260"
                                                                 Duration="0:0:0.18">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseIn"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.1"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <Border Background="{ui:ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <Grid Margin="10,10,10,18">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="実行前チェック"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>

                                    <ui:Button Grid.Column="1"
                                               Command="{Binding ClosePreflightPanelCommand}"
                                               ToolTip="診断パネルを閉じる"
                                               Width="28"
                                               Height="28"
                                               Padding="0"
                                               Appearance="Transparent"
                                               Icon="{ui:SymbolIcon Dismiss24}"/>
                                </Grid>

                                <TextBlock Grid.Row="1"
                                           Text="{Binding PreflightSummary}"
                                           Margin="0,4,0,8"
                                           Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>

                                <Border Grid.Row="2"
                                        Background="{ui:ThemeResource ControlFillColorDefaultBrush}"
                                        BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="6">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding PreflightIssues}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}"
                                                            BorderThickness="0,0,0,1"
                                                            Padding="0,4">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="58"/>
                                                                <ColumnDefinition Width="130"/>
                                                                <ColumnDefinition Width="100"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0"
                                                                       Text="{Binding Line}"
                                                                       FontWeight="SemiBold"/>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding CommandName}"
                                                                       Margin="8,0,0,0"/>
                                                            <TextBlock Grid.Column="2"
                                                                       Text="{Binding PropertyName}"
                                                                       Margin="8,0,0,0"
                                                                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                                                            <TextBlock Grid.Column="3"
                                                                       Text="{Binding Message}"
                                                                       Margin="8,0,0,0"
                                                                       TextWrapping="Wrap"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                </Border>

                <GridSplitter Grid.Row="1"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              ResizeDirection="Rows"
                              ResizeBehavior="PreviousAndNext"
                              Background="{ui:ThemeResource ControlStrokeColorDefaultBrush}">
                    <GridSplitter.Style>
                        <Style TargetType="GridSplitter">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBottomPanelOpen}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </GridSplitter.Style>
                </GridSplitter>

                <Border Grid.Row="2"
                        Height="280"
                        Margin="0,8,0,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBottomPanelOpen}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Border Background="{ui:ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <Grid Margin="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,6">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="ログ"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsVariablePanelOpen}" Value="True">
                                                    <Setter Property="Text" Value="変数"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <panels:LogPanel Grid.Row="1" DataContext="{Binding LogPanelViewModel}">
                                    <panels:LogPanel.Style>
                                        <Style TargetType="panels:LogPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.IsLogPanelOpen, RelativeSource={RelativeSource AncestorType=Grid}}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </panels:LogPanel.Style>
                                </panels:LogPanel>

                                <panels:VariablePanel Grid.Row="1" DataContext="{Binding VariablePanelViewModel}">
                                    <panels:VariablePanel.Style>
                                        <Style TargetType="panels:VariablePanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.IsVariablePanelOpen, RelativeSource={RelativeSource AncestorType=Grid}}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </panels:VariablePanel.Style>
                                </panels:VariablePanel>
                            </Grid>
                        </Grid>
                    </Border>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="1"
                          Margin="0,0,0,8"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"
                          Background="{ui:ThemeResource ControlStrokeColorDefaultBrush}">
                <GridSplitter.Style>
                    <Style TargetType="GridSplitter">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsFavoritePanelOpen}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </GridSplitter.Style>
            </GridSplitter>

            <Grid Grid.Column="2" Margin="0,0,8,8">
                <ui:Card Padding="0" Margin="8,0,0,0" MinWidth="240" MaxWidth="700">
                    <ui:Card.Style>
                        <Style TargetType="ui:Card">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFavoritePanelOpen}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Card.Style>
                    <panels:FavoritePanel DataContext="{Binding FavoritePanelViewModel}"/>
                </ui:Card>
            </Grid>

        </Grid>
    </Grid>
</UserControl>
