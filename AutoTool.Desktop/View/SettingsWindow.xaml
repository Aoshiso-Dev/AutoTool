<ui:FluentWindow x:Class="AutoTool.Desktop.View.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="設定"
        Width="520"
        Height="340"
        MinWidth="460"
        MinHeight="320"
        WindowStartupLocation="CenterOwner"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:Card Grid.Row="0" Padding="16">
            <StackPanel>
                <TextBlock Text="起動設定" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <CheckBox x:Name="RestorePreviousSessionCheckBox"
                          Content="前回終了時の状態を次回起動時に復元する"
                          ToolTip="タブ状態、パネル開閉状態、最後に開いたマクロを復元します。"/>
                <TextBlock Text="メインウィンドウサイズ"
                           Margin="0,14,0,4"
                           FontWeight="SemiBold"/>
                <ComboBox x:Name="WindowSizePresetComboBox"
                          SelectedIndex="1">
                    <ComboBoxItem Content="S（コンパクト: 作業領域の30%）"/>
                    <ComboBoxItem Content="M（標準: 作業領域の50%）"/>
                    <ComboBoxItem Content="L（広め: 作業領域の70%）"/>
                </ComboBox>
                <TextBlock Text="変更内容は保存時に即時適用され、次回起動時にも引き継がれます。"
                           Margin="0,10,0,0"
                           Opacity="0.8"/>
            </StackPanel>
        </ui:Card>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <ui:Button Content="キャンセル" Appearance="Secondary" Width="110" Margin="0,0,8,0" Click="CancelButton_Click"/>
            <ui:Button Content="保存" Appearance="Primary" Width="110" Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
