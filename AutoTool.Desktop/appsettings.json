{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "UiState": {
    "RestorePreviousSession": true
  },
  "CommandEventBus": {
    "SubscriberBufferSize": 2048,
    "DropWarningInitialThreshold": 1,
    "DropWarningInterval": 100
  }
}
