<ui:FluentWindow x:Class="AutoTool.Desktop.Panels.View.CommandSelectionWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:converter="clr-namespace:AutoTool.Desktop.Panels.View.Converter"
                 Title="コマンドを選択"
                 Width="920"
                 Height="620"
                 WindowStartupLocation="CenterOwner"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round"
                 ResizeMode="CanResize">
    <ui:FluentWindow.Resources>
        <converter:CommandTypeToFluentIconConverter x:Key="CommandTypeToFluentIconConverter"/>
    </ui:FluentWindow.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="14"
                CornerRadius="10"
                Margin="0,0,0,12"
                Background="{ui:ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ui:SymbolIcon Grid.Column="0" Symbol="Search24" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center"
                         MinHeight="36"/>
                <TextBlock Grid.Column="2"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                           Text="{Binding CommandItemsView.Count, StringFormat=候補: {0}件}"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="8"
                    CornerRadius="10"
                    Background="{ui:ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <ListBox ItemsSource="{Binding CommandItemsView}"
                         SelectedItem="{Binding SelectedCommand, Mode=TwoWay}"
                         BorderThickness="0"
                         Background="Transparent"
                         MouseDoubleClick="CommandListView_OnMouseDoubleClick"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Margin" Value="0,0,0,8"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="CardBorder"
                                                Padding="14"
                                                CornerRadius="10"
                                                Background="{ui:ThemeResource ControlFillColorSecondaryBrush}"
                                                BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}"
                                                BorderThickness="1">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="CardBorder" Property="Background" Value="{ui:ThemeResource ControlFillColorDefaultBrush}"/>
                                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="{ui:ThemeResource ControlStrokeColorSecondaryBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="CardBorder" Property="Background" Value="{ui:ThemeResource ControlFillColorDefaultBrush}"/>
                                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="{ui:ThemeResource ControlStrokeColorSecondaryBrush}"/>
                                                <Setter TargetName="CardBorder" Property="BorderThickness" Value="2"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Row="0"
                                            Grid.Column="0"
                                            Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="{Binding TypeName, Converter={StaticResource CommandTypeToFluentIconConverter}}"
                                                   Margin="0,0,8,0"
                                                   FontSize="18"
                                                   VerticalAlignment="Center"/>
                                    <TextBlock FontSize="16"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Text="{Binding DisplayName}"/>
                                </StackPanel>

                                <Border Grid.Row="0"
                                        Grid.Column="1"
                                        Padding="8,2"
                                        CornerRadius="6"
                                        Background="{ui:ThemeResource ControlFillColorDefaultBrush}"
                                        BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}"
                                        BorderThickness="1">
                                    <TextBlock FontSize="12"
                                               Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                               Text="{Binding Category}"/>
                                </Border>

                                <TextBlock Grid.Row="1"
                                           Grid.ColumnSpan="2"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap"
                                           Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                           Text="{Binding Description}"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Border Grid.Column="1"
                    Margin="12,0,0,0"
                    Padding="16"
                    CornerRadius="10"
                    Background="{ui:ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="選択中のコマンド"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                    <StackPanel Margin="0,6,0,2"
                                Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="{Binding SelectedCommand.TypeName, Converter={StaticResource CommandTypeToFluentIconConverter}}"
                                       Margin="0,0,8,0"
                                       FontSize="22"
                                       VerticalAlignment="Center"/>
                        <TextBlock FontSize="22"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Text="{Binding SelectedCommand.DisplayName, TargetNullValue=未選択}" />
                    </StackPanel>
                    <Border Padding="8,2"
                            CornerRadius="6"
                            HorizontalAlignment="Left"
                            Background="{ui:ThemeResource ControlFillColorDefaultBrush}"
                            BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <TextBlock FontSize="12"
                                   Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                   Text="{Binding SelectedCommand.Category, TargetNullValue=カテゴリなし}"/>
                    </Border>

                    <TextBlock Margin="0,14,0,6"
                               Text="説明"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                    <Border Padding="12"
                            CornerRadius="8"
                            Background="{ui:ThemeResource ControlFillColorDefaultBrush}"
                            BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <TextBlock Text="{Binding SelectedDescription}" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2"
                    Margin="0,12,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <ui:Button Content="キャンセル"
                       Width="120"
                       Margin="0,0,8,0"
                       Appearance="Secondary"
                       IsCancel="True" />
            <ui:Button Content="追加"
                       Width="120"
                       Appearance="Primary"
                       IsEnabled="{Binding CanConfirm}"
                       Click="ConfirmButton_OnClick" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
