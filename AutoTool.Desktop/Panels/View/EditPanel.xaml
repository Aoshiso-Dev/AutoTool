<UserControl x:Class="AutoTool.Desktop.Panels.View.EditPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:converter="clr-namespace:AutoTool.Desktop.Panels.View.Converter"
             xmlns:editors="clr-namespace:AutoTool.Desktop.Panels.View.Editors"
             xmlns:attrs="clr-namespace:AutoTool.Automation.Runtime.Attributes;assembly=AutoTool.Infrastructure"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Editors/EditorTemplates.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <converter:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <converter:BoolToVisibilityMultiConverter x:Key="BoolToVisibilityMultiConverter"/>
            <converter:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
            <converter:KeyToStringConverter x:Key="KeyToStringConverter"/>
            
            <Style x:Key="SettingCard" TargetType="Border">
                <Setter Property="Background" Value="{ui:ThemeResource ControlFillColorDefaultBrush}"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="16,12"/>
                <Setter Property="Margin" Value="0,0,0,4"/>
            </Style>
            
            <Style x:Key="SettingLabel" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
            
            <Style x:Key="SettingDescription" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBooleanConverter}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="4">
                
                <!-- 空リスト時のメッセージ -->
                <StackPanel Visibility="{Binding IsListEmpty, Converter={StaticResource BoolToVisibilityConverter}}" 
                            Margin="0,60" HorizontalAlignment="Center">
                    <ui:SymbolIcon Symbol="DocumentAdd24" FontSize="48" 
                                   Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"/>
                    <TextBlock Text="コマンドを追加してください" 
                               Style="{StaticResource SettingLabel}"
                               HorizontalAlignment="Center" Margin="0,16,0,8"/>
                    <TextBlock Text="「追加」ボタンからコマンドを登録できます" 
                               Style="{StaticResource SettingDescription}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- 未選択時のメッセージ -->
                <StackPanel Visibility="{Binding IsListNotEmptyButNoSelection, Converter={StaticResource BoolToVisibilityConverter}}" 
                            Margin="0,60" HorizontalAlignment="Center">
                    <ui:SymbolIcon Symbol="CursorClick24" FontSize="48" 
                                   Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"/>
                    <TextBlock Text="コマンドを選択してください" 
                               Style="{StaticResource SettingLabel}"
                               HorizontalAlignment="Center" Margin="0,16,0,8"/>
                    <TextBlock Text="一覧からコマンドを選ぶと設定を編集できます" 
                               Style="{StaticResource SettingDescription}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Dynamic property editors based on metadata -->
                <StackPanel Visibility="{Binding IsNotNullItem, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Border Background="#12EF4444"
                            BorderBrush="#EF4444"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10"
                            Margin="0,0,0,8"
                            Visibility="{Binding HasValidationErrors, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="入力エラーがあります"
                                       FontWeight="SemiBold"
                                       Foreground="#C42B1C"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding ValidationSummary}"
                                       TextWrapping="Wrap"
                                       Foreground="#C42B1C"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{ui:ThemeResource ControlFillColorSecondaryBrush}"
                            BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10"
                            Margin="0,0,0,8"
                            Visibility="{Binding IsOcrPreviewAvailable, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock Text="OCRプレビュー"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <ui:Button Content="自動調整"
                                               Command="{Binding RunOcrAutoTuneCommand}"
                                               Height="30"
                                               MinWidth="88"
                                               Margin="0,0,8,0"/>
                                    <ui:Button Content="テスト実行"
                                            Command="{Binding RunOcrPreviewCommand}"
                                            Appearance="Primary"
                                            Height="30"
                                            MinWidth="88"/>
                                </StackPanel>
                            </DockPanel>
                            <TextBlock Text="{Binding OcrPreviewSummary}"
                                       TextWrapping="Wrap"
                                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding OcrAutoTuneSummary}"
                                       TextWrapping="Wrap"
                                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding OcrPreviewConfidenceText}"
                                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,4"
                                       Visibility="{Binding HasOcrPreviewResult, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <TextBox Text="{Binding OcrPreviewText}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     MinHeight="54"
                                      MaxHeight="120"
                                      Visibility="{Binding HasOcrPreviewResult, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{ui:ThemeResource ControlFillColorSecondaryBrush}"
                            BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10"
                            Margin="0,0,0,8"
                            Visibility="{Binding IsImageSearchPreviewAvailable, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock Text="画像検索テスト"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <ui:Button Content="自動調整"
                                               Command="{Binding RunImageSearchAutoTuneCommand}"
                                               Height="30"
                                               MinWidth="88"
                                               Margin="0,0,8,0"/>
                                    <ui:Button Content="テスト実行"
                                           Command="{Binding RunImageSearchPreviewCommand}"
                                           Appearance="Primary"
                                           Height="30"
                                           MinWidth="88"/>
                                </StackPanel>
                            </DockPanel>
                            <TextBlock Text="{Binding ImageSearchPreviewSummary}"
                                       TextWrapping="Wrap"
                                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding ImageSearchAutoTuneSummary}"
                                       TextWrapping="Wrap"
                                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding ImageSearchSearchArea}"
                                       TextWrapping="Wrap"
                                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,4"
                                       Visibility="{Binding HasImageSearchPreviewResult, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <TextBlock Text="{Binding ImageSearchPreviewDetail}"
                                       TextWrapping="Wrap"
                                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,4"
                                       Visibility="{Binding HasImageSearchPreviewResult, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <TextBox Text="{Binding ImageSearchRecoveryGuide}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     MinHeight="54"
                                     MaxHeight="120"
                                     Visibility="{Binding HasImageSearchPreviewResult, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{ui:ThemeResource ControlFillColorSecondaryBrush}"
                            BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10"
                            Margin="0,0,0,8"
                            Visibility="{Binding IsAiDetectionPreviewAvailable, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock Text="AI検出テスト"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <ui:Button Content="自動調整"
                                               Command="{Binding RunAiDetectionAutoTuneCommand}"
                                               Height="30"
                                               MinWidth="88"
                                               Margin="0,0,8,0"/>
                                    <ui:Button Content="テスト実行"
                                           Command="{Binding RunAiDetectionPreviewCommand}"
                                           Appearance="Primary"
                                           Height="30"
                                           MinWidth="88"/>
                                </StackPanel>
                            </DockPanel>
                            <TextBlock Text="{Binding AiDetectionPreviewSummary}"
                                       TextWrapping="Wrap"
                                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding AiDetectionAutoTuneSummary}"
                                       TextWrapping="Wrap"
                                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding AiDetectionSearchArea}"
                                       TextWrapping="Wrap"
                                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,4"
                                       Visibility="{Binding HasAiDetectionPreviewResult, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <TextBlock Text="{Binding AiDetectionPreviewDetail}"
                                       TextWrapping="Wrap"
                                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,4"
                                       Visibility="{Binding HasAiDetectionPreviewResult, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <TextBox Text="{Binding AiDetectionRecoveryGuide}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     MinHeight="54"
                                     MaxHeight="120"
                                     Visibility="{Binding HasAiDetectionPreviewResult, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </Border>

                    <ItemsControl ItemsSource="{Binding PropertyGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,8">
                                    <TextBlock Text="{Binding GroupName}" 
                                               FontSize="12" FontWeight="SemiBold" 
                                               Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                               Margin="4,8,0,4"/>
                                    <ItemsControl ItemsSource="{Binding Properties}"
                                                  ItemTemplateSelector="{StaticResource EditorTemplateSelector}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- プレビュー領域（画像系コマンド向け） -->
        <Border Grid.Row="1" Background="{ui:ThemeResource ControlFillColorDefaultBrush}" 
                CornerRadius="8" Margin="4" Padding="12"
                Visibility="{Binding HasImagePreview, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel>
                <TextBlock Text="プレビュー" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"
                           Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                <Border CornerRadius="4" Background="{ui:ThemeResource ControlFillColorSecondaryBrush}"
                        MinHeight="100" MaxHeight="200">
                    <Image Source="{Binding PreviewImagePath}" Stretch="Uniform" MaxHeight="180"/>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>



