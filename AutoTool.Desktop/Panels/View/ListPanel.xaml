<UserControl x:Class="AutoTool.Desktop.Panels.View.ListPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:converter="clr-namespace:AutoTool.Desktop.Panels.View.Converter"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="800">

    <UserControl.Resources>
        <converter:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <converter:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converter:NumberToBooleanConverter x:Key="NumberToBooleanConverter"/>
        <converter:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <converter:ValidationErrorContainsItemConverter x:Key="ValidationErrorContainsItemConverter"/>
        <converter:NestLevelToMarginConverter x:Key="NestLevelToMarginConverter"/>
        <converter:CommandTypeToCategoryColorConverter x:Key="CommandTypeToCategoryColorConverter"/>
        <converter:CommandTypeToCompactNameConverter x:Key="CommandTypeToCompactNameConverter"/>
        <converter:CommandTypeToFluentIconConverter x:Key="CommandTypeToFluentIconConverter"/>
        <converter:CommandDescriptionToMultilineConverter x:Key="CommandDescriptionToMultilineConverter"/>
        <converter:CommandIndentMarginConverter x:Key="CommandIndentMarginConverter"/>
        <converter:CommandToggleLeadingMarginConverter x:Key="CommandToggleLeadingMarginConverter"/>
        <converter:CommandRowCollapsedConverter x:Key="CommandRowCollapsedConverter"/>
        <converter:CommandBlockToggleVisibilityConverter x:Key="CommandBlockToggleVisibilityConverter"/>
        <converter:CommandBlockToggleGlyphConverter x:Key="CommandBlockToggleGlyphConverter"/>
        <converter:ProgressToWidthConverter x:Key="ProgressToWidthConverter"/>
    </UserControl.Resources>

    <Grid>
        <!-- ui:DataGrid を使用してテーマを継承 -->
        <ui:DataGrid x:Name="CommandDataGrid"
                     ItemsSource="{Binding CommandList.Items}" 
                     SelectedIndex="{Binding SelectedLineNumber, Mode=TwoWay}"
                     AllowDrop="True"
                     SelectionMode="Extended" 
                     HeadersVisibility="Column" 
                     CanUserAddRows="False" 
                     CanUserDeleteRows="False"
                     AutoGenerateColumns="False" 
                     EnableRowVirtualization="False"
                     EnableColumnVirtualization="False"
                     CanUserReorderColumns="False"
                     CanUserSortColumns="False"
                     GridLinesVisibility="None"
                     BorderThickness="0"
                     VirtualizingPanel.IsVirtualizing="False"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     PreviewMouseLeftButtonDown="CommandDataGrid_PreviewMouseLeftButtonDown"
                     MouseMove="CommandDataGrid_MouseMove"
                     DragOver="CommandDataGrid_DragOver"
                     DragLeave="CommandDataGrid_DragLeave"
                     Drop="CommandDataGrid_Drop"
                     VerticalContentAlignment="Center"
                     VerticalAlignment="Stretch"
                     HorizontalAlignment="Stretch">

            <ui:DataGrid.Resources>
                <Style TargetType="{x:Type ScrollContentPresenter}">
                    <Setter Property="VerticalAlignment" Value="Top"/>
                </Style>
            </ui:DataGrid.Resources>

            <ui:DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="TextBlock.TextAlignment" Value="Left"/>
                    <Setter Property="Background" Value="{ui:ThemeResource ControlFillColorSecondaryBrush}"/>
                    <Setter Property="Foreground" Value="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                    <Setter Property="Padding" Value="8,4,8,4"/>
                </Style>
            </ui:DataGrid.ColumnHeaderStyle>

            <!-- 選択行のハイライトスタイル -->
            <ui:DataGrid.RowStyle>
                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding DataContext.IsAllSelectedVisual, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" Value="True">
                            <Setter Property="Background" Value="#3050A0FF"/>
                            <Setter Property="BorderBrush" Value="#50A0FF"/>
                            <Setter Property="BorderThickness" Value="2,0,0,0"/>
                        </DataTrigger>
                        <!-- 選択時のハイライト -->
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#3050A0FF"/>
                            <Setter Property="BorderBrush" Value="#50A0FF"/>
                            <Setter Property="BorderThickness" Value="2,0,0,0"/>
                        </Trigger>
                        <!-- マウスホバー時 -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#1550A0FF"/>
                        </Trigger>
                        <!-- 選択 + ホバー -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="True"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter Property="Background" Value="#4050A0FF"/>
                        </MultiTrigger>
                        <DataTrigger Value="True">
                            <DataTrigger.Binding>
                                <MultiBinding Converter="{StaticResource ValidationErrorContainsItemConverter}">
                                    <Binding/>
                                    <Binding Path="DataContext.ValidationErrorItems" RelativeSource="{RelativeSource AncestorType={x:Type UserControl}}"/>
                                </MultiBinding>
                            </DataTrigger.Binding>
                            <Setter Property="Background" Value="#20DC2626"/>
                            <Setter Property="BorderBrush" Value="#C81E1E"/>
                            <Setter Property="BorderThickness" Value="2,0,0,0"/>
                        </DataTrigger>
                        <DataTrigger Value="True">
                            <DataTrigger.Binding>
                                <MultiBinding Converter="{StaticResource CommandRowCollapsedConverter}">
                                    <Binding/>
                                    <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType={x:Type UserControl}}"/>
                                    <Binding Path="DataContext.CollapsedStateVersion" RelativeSource="{RelativeSource AncestorType={x:Type UserControl}}"/>
                                </MultiBinding>
                            </DataTrigger.Binding>
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ui:DataGrid.RowStyle>

            <!-- セルの選択色を上書き -->
            <ui:DataGrid.CellStyle>
                <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                    <Setter Property="Padding" Value="3,0"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="True"/>
                                <Condition Property="Selector.IsSelectionActive" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                        </MultiTrigger>
                    </Style.Triggers>
                </Style>
            </ui:DataGrid.CellStyle>

            <ui:DataGrid.Columns>
                <!-- 有効/無効 -->
                <DataGridTemplateColumn x:Name="EnableColumn" Width="60" Header="">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ui:ToggleSwitch IsChecked="{Binding IsEnable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                             IsEnabled="{Binding DataContext.IsRunning, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Converter={StaticResource InverseBooleanConverter}}"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Margin="0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- 行番号 -->
                <DataGridTemplateColumn x:Name="LineNumberColumn" Header="#" Width="35">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid>
                                    <Grid Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ui:ProgressRing Width="24"
                                                        Height="24"
                                                        Progress="{Binding Progress}"
                                                        IsIndeterminate="False"/>
                                        <TextBlock Text="{Binding Progress, StringFormat={}{0}%}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="8"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"/>
                                    </Grid>
                                    <TextBlock Text="{Binding LineNumber}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               Opacity="0.5"
                                               Visibility="{Binding IsRunning, Converter={StaticResource InverseBooleanConverter}}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Value="True">
                                                        <DataTrigger.Binding>
                                                            <MultiBinding Converter="{StaticResource ValidationErrorContainsItemConverter}">
                                                                <Binding/>
                                                                <Binding Path="DataContext.ValidationErrorItems" RelativeSource="{RelativeSource AncestorType={x:Type UserControl}}"/>
                                                            </MultiBinding>
                                                        </DataTrigger.Binding>
                                                        <Setter Property="Opacity" Value="0.95"/>
                                                        <Setter Property="Foreground" Value="#C81E1E"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- コマンド -->
                <DataGridTemplateColumn x:Name="CommandColumn" Header="コマンド" Width="210">
                    <DataGridTemplateColumn.CellStyle>
                        <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                </Trigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsSelected" Value="True"/>
                                        <Condition Property="Selector.IsSelectionActive" Value="False"/>
                                    </MultiTrigger.Conditions>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                </MultiTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTemplateColumn.CellStyle>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid Margin="0" VerticalAlignment="Stretch">
                                    <Border
                                        CornerRadius="4"
                                        Padding="8,0"
                                        VerticalAlignment="Stretch">
                                        <Border.Margin>
                                            <MultiBinding Converter="{StaticResource CommandIndentMarginConverter}">
                                                <Binding/>
                                                <Binding Path="DataContext.CommandList.Items" RelativeSource="{RelativeSource AncestorType={x:Type UserControl}}"/>
                                                <Binding Path="DataContext.CollapsedStateVersion" RelativeSource="{RelativeSource AncestorType={x:Type UserControl}}"/>
                                            </MultiBinding>
                                        </Border.Margin>
                                    <Grid>
                                        <ui:Button Width="18"
                                                   Height="18"
                                                   MinWidth="18"
                                                   MinHeight="18"
                                                   Padding="0"
                                                   BorderThickness="0"
                                                   Appearance="Secondary"
                                                   Background="Transparent"
                                                   Foreground="#FFFFFF"
                                                   FontSize="10"
                                                   FontFamily="Segoe UI"
                                                   FocusVisualStyle="{x:Null}"
                                                   Focusable="False"
                                                   Click="ToggleBlockCollapseButton_Click"
                                                   IsEnabled="{Binding DataContext.IsRunning, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Converter={StaticResource InverseBooleanConverter}}"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Center"
                                                   Margin="-20,0,2,0">
                                            <ui:Button.Visibility>
                                                <MultiBinding Converter="{StaticResource CommandBlockToggleVisibilityConverter}">
                                                    <Binding/>
                                                    <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType={x:Type UserControl}}"/>
                                                    <Binding Path="DataContext.CollapsedStateVersion" RelativeSource="{RelativeSource AncestorType={x:Type UserControl}}"/>
                                                </MultiBinding>
                                            </ui:Button.Visibility>
                                            <ui:Button.Content>
                                                <MultiBinding Converter="{StaticResource CommandBlockToggleGlyphConverter}">
                                                    <Binding/>
                                                    <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType={x:Type UserControl}}"/>
                                                    <Binding Path="DataContext.CollapsedStateVersion" RelativeSource="{RelativeSource AncestorType={x:Type UserControl}}"/>
                                                </MultiBinding>
                                            </ui:Button.Content>
                                        </ui:Button>
                                        <DockPanel LastChildFill="True" VerticalAlignment="Center">
                                            <Border Width="22"
                                                    Height="22"
                                                    CornerRadius="4"
                                                    Background="{Binding ItemType, Converter={StaticResource CommandTypeToCategoryColorConverter}}"
                                                    Padding="3,0"
                                                    Margin="0,0,8,0"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Left">
                                                <ui:SymbolIcon Symbol="{Binding ItemType, Converter={StaticResource CommandTypeToFluentIconConverter}}" 
                                                               Foreground="#FFFFFF"
                                                               FontSize="16">
                                                    <ui:SymbolIcon.Effect>
                                                        <DropShadowEffect BlurRadius="2"
                                                                          Direction="315"
                                                                          ShadowDepth="1"
                                                                          Opacity="0.75"
                                                                          Color="#99000000"/>
                                                    </ui:SymbolIcon.Effect>
                                                </ui:SymbolIcon>
                                            </Border>
                                            <TextBlock Text="{Binding ItemType, Converter={StaticResource CommandTypeToCompactNameConverter}}" 
                                                       FontWeight="Medium"
                                                       FontSize="11"
                                                       TextTrimming="None"
                                                       LineHeight="14"
                                                       LineStackingStrategy="BlockLineHeight"
                                                       FontFamily="Segoe UI"
                                                       VerticalAlignment="Center"
                                                       Foreground="#FFFFFF"/>
                                        </DockPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- 説明 -->
                <DataGridTemplateColumn x:Name="DescriptionColumn" Header="説明" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel VerticalAlignment="Center"
                                        HorizontalAlignment="Stretch">
                                <TextBlock Text="{Binding Comment}"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           VerticalAlignment="Center"
                                           FontSize="{Binding FontSize, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                           LineHeight="16"
                                           LineStackingStrategy="BlockLineHeight"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"
                                           FontWeight="SemiBold"
                                           ToolTip="{Binding Description, Converter={StaticResource CommandDescriptionToMultilineConverter}}"
                                           ToolTipService.ShowDuration="120000"
                                           ToolTipService.InitialShowDelay="120"
                                           ToolTipService.BetweenShowDelay="120"
                                           ToolTipService.ShowOnDisabled="True"
                                           Visibility="{Binding HasComment, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Value="True">
                                                    <DataTrigger.Binding>
                                                        <MultiBinding Converter="{StaticResource ValidationErrorContainsItemConverter}">
                                                            <Binding/>
                                                            <Binding Path="DataContext.ValidationErrorItems" RelativeSource="{RelativeSource AncestorType={x:Type UserControl}}"/>
                                                        </MultiBinding>
                                                    </DataTrigger.Binding>
                                                    <Setter Property="Foreground" Value="#C81E1E"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- 行移動 -->
                <DataGridTemplateColumn x:Name="MoveColumn" Header="" Width="52">
                    <DataGridTemplateColumn.CellStyle>
                        <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                </Trigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsSelected" Value="True"/>
                                        <Condition Property="Selector.IsSelectionActive" Value="False"/>
                                    </MultiTrigger.Conditions>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                </MultiTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTemplateColumn.CellStyle>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                <ui:Button Icon="{ui:SymbolIcon ArrowUp24}"
                                           Appearance="Secondary"
                                           Click="MoveUpCommandButton_Click"
                                           ToolTip="1行上へ移動"
                                           Padding="0"
                                           Margin="0"
                                           Width="{Binding RowHeight, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                           Height="{Binding RowHeight, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                           MinWidth="0"
                                           MinHeight="0"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           IsEnabled="{Binding DataContext.IsRunning, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Converter={StaticResource InverseBooleanConverter}}"/>
                                <ui:Button Icon="{ui:SymbolIcon ArrowDown24}"
                                           Appearance="Secondary"
                                           Click="MoveDownCommandButton_Click"
                                           ToolTip="1行下へ移動"
                                           Padding="0"
                                           Margin="2,0,0,0"
                                           Width="{Binding RowHeight, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                           Height="{Binding RowHeight, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                           MinWidth="0"
                                           MinHeight="0"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           IsEnabled="{Binding DataContext.IsRunning, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Converter={StaticResource InverseBooleanConverter}}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- 行削除 -->
                <DataGridTemplateColumn x:Name="DeleteColumn" Header="" Width="36">
                    <DataGridTemplateColumn.CellStyle>
                        <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                </Trigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsSelected" Value="True"/>
                                        <Condition Property="Selector.IsSelectionActive" Value="False"/>
                                    </MultiTrigger.Conditions>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                </MultiTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTemplateColumn.CellStyle>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ui:Button Icon="{ui:SymbolIcon Delete24}"
                                       Appearance="Secondary"
                                       Click="DeleteCommandButton_Click"
                                       ToolTip="このコマンドを削除"
                                       Padding="0"
                                       Margin="0"
                                       Width="{Binding RowHeight, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                       Height="{Binding RowHeight, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                       MinWidth="0"
                                       MinHeight="0"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       IsEnabled="{Binding DataContext.IsRunning, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Converter={StaticResource InverseBooleanConverter}}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- 設定編集ボタン -->
                <DataGridTemplateColumn x:Name="EditColumn" Header="" Width="40">
                    <DataGridTemplateColumn.CellStyle>
                        <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                </Trigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsSelected" Value="True"/>
                                        <Condition Property="Selector.IsSelectionActive" Value="False"/>
                                    </MultiTrigger.Conditions>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                </MultiTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTemplateColumn.CellStyle>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ui:Button Icon="{ui:SymbolIcon Settings24}" 
                                       Appearance="Secondary"
                                       Click="EditSettingsButton_Click"
                                       ToolTip="設定を編集"
                                       Padding="0"
                                       Margin="0"
                                       Width="{Binding RowHeight, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                       Height="{Binding RowHeight, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                       MinWidth="0"
                                       MinHeight="0"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       IsEnabled="{Binding DataContext.IsRunning, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Converter={StaticResource InverseBooleanConverter}}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </ui:DataGrid.Columns>
        </ui:DataGrid>

        <Border x:Name="DropInsertIndicator"
                Visibility="Collapsed"
                Height="2"
                Background="#FF2F89FF"
                BorderBrush="#FFFFFFFF"
                BorderThickness="0,1,0,1"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                Margin="0,0,0,0"
                IsHitTestVisible="False"
                Panel.ZIndex="10"/>
    </Grid>
</UserControl>
