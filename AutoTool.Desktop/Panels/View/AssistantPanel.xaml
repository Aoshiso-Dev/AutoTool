<UserControl x:Class="AutoTool.Desktop.Panels.View.AssistantPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:shared="clr-namespace:AutoTool.Desktop.Panels.ViewModel.Shared"
             mc:Ignorable="d"
             d:DesignHeight="220" d:DesignWidth="800">

    <Grid Background="{ui:ThemeResource SolidBackgroundFillColorBaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="{Binding ConnectionStatus}"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"
                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>

            <TextBlock Grid.Column="1"
                       Text="ローカルAIの回答は提案です。実行前に内容を確認してください。"
                       VerticalAlignment="Center"
                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                       TextTrimming="CharacterEllipsis"/>

            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="8,0,0,0">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <ui:ProgressRing Width="18"
                                 Height="18"
                                 IsIndeterminate="True"/>
                <TextBlock Text="生成中..."
                           Margin="6,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <ui:Button Grid.Column="3"
                       Content="マクロ生成"
                       Command="{Binding GenerateMacroCommand}"
                       Height="30"
                       MinWidth="92"
                       Margin="8,0,0,0"
                       Appearance="Primary"/>

            <ui:Button Grid.Column="4"
                       Content="履歴追加"
                       Command="{Binding ReplayLatestMacroCommand}"
                       Height="30"
                       MinWidth="84"
                       Margin="8,0,0,0"
                       Appearance="Secondary"/>

            <ui:Button Grid.Column="5"
                       Content="履歴"
                       Command="{Binding ShowMacroHistoryCommand}"
                       Height="30"
                       MinWidth="64"
                       Margin="8,0,0,0"
                       Appearance="Secondary"/>

            <ui:Button Grid.Column="6"
                       Content="マクロ説明"
                       Command="{Binding ExplainMacroCommand}"
                       Height="30"
                       MinWidth="92"
                       Margin="8,0,0,0"
                       Appearance="Secondary"/>

            <ui:Button Grid.Column="7"
                       Content="接続テスト"
                       Command="{Binding TestConnectionCommand}"
                       Height="30"
                       MinWidth="92"
                       Margin="8,0,0,0"
                       Appearance="Secondary"/>

            <ui:Button Grid.Column="8"
                       Icon="{ui:SymbolIcon Dismiss24}"
                       Command="{Binding CancelRequestCommand}"
                       ToolTip="AI相談をキャンセル"
                       Width="34"
                       Height="30"
                       Margin="8,0,0,0"
                       Appearance="Transparent"/>
        </Grid>

        <Border Grid.Row="1"
                BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Background="{ui:ThemeResource ControlFillColorDefaultBrush}">
            <Grid>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="0">
                    <ItemsControl ItemsSource="{Binding Messages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type shared:AssistantMessage}">
                            <Border Padding="8,5"
                                    Margin="4,3"
                                    CornerRadius="6"
                                    BorderThickness="2,0,0,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="#64748B"/>
                                        <Setter Property="Background" Value="{ui:ThemeResource SolidBackgroundFillColorBaseBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                <Setter Property="BorderBrush" Value="#10B981"/>
                                                <Setter Property="Background" Value="{ui:ThemeResource ControlFillColorDefaultBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <DockPanel Grid.Row="0" LastChildFill="True">
                                        <TextBlock DockPanel.Dock="Right"
                                                   Text="{Binding Timestamp}"
                                                   Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                                   FontSize="11"/>
                                        <TextBlock Text="{Binding Sender}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                                   FontSize="12"/>
                                    </DockPanel>

                                    <Grid Grid.Row="1"
                                          Margin="0,3,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <ui:ProgressRing Grid.Column="0"
                                                         Width="18"
                                                         Height="18"
                                                         Margin="0,1,8,0"
                                                         IsIndeterminate="True">
                                            <ui:ProgressRing.Style>
                                                <Style TargetType="ui:ProgressRing">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPending}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:ProgressRing.Style>
                                        </ui:ProgressRing>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Text}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                                    </Grid>
                                </Grid>
                            </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <TextBlock Text="質問を入力するか、マクロ説明を実行してください。"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Messages.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.ColumnSpan="2"
                       Text="質問"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4"
                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>

            <Grid Grid.Row="1"
                  Grid.Column="0">
                <TextBox Height="38"
                         Padding="10,0"
                         BorderThickness="1"
                         VerticalContentAlignment="Center"
                         Text="{Binding QuestionText, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="AI相談へ送る質問"/>
                <TextBlock Text="ここにAIへ相談したい内容を入力"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False"
                           Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding QuestionText}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <Grid Grid.Row="1"
                  Grid.Column="1"
                  Margin="8,0,0,0">
                <ui:Button Content="送信"
                           Command="{Binding SendQuestionCommand}"
                           Height="38"
                           MinWidth="82"
                           Appearance="Primary">
                    <ui:Button.Style>
                        <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Button.Style>
                </ui:Button>

                <ui:Button Content="停止"
                           Command="{Binding CancelRequestCommand}"
                           Height="38"
                           MinWidth="82"
                           Appearance="Danger">
                    <ui:Button.Style>
                        <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Button.Style>
                </ui:Button>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
