<UserControl x:Class="AutoTool.Panels.View.FavoritePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="340">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="お気に入り"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
            <TextBlock Text="現在のコマンド一覧を保存して、あとで読み込みできます。"
                       FontSize="12"
                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,2,0,8"/>

            <DockPanel>
                <TextBox Text="{Binding FavoriteName, UpdateSourceTrigger=PropertyChanged}"
                         MinWidth="200"
                         Height="32"
                         VerticalContentAlignment="Center"
                         Margin="0,0,8,0"/>
                <ui:Button Content="追加"
                           Command="{Binding AddFavoriteFromCurrentCommand}"
                           Appearance="Primary"
                           Width="64"
                           Height="32"
                           DockPanel.Dock="Right"/>
            </DockPanel>
        </StackPanel>

        <DockPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock Text="一覧から選択して操作"
                       VerticalAlignment="Center"
                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                <ui:Button Content="読み込み"
                           Command="{Binding LoadSelectedFavoriteCommand}"
                           Appearance="Primary"
                           Height="32"
                           Margin="0,0,8,0"/>
                <ui:Button Content="削除"
                           Command="{Binding DeleteSelectedFavoriteCommand}"
                           Appearance="Secondary"
                           Height="32"/>
            </StackPanel>
        </DockPanel>

        <ui:DataGrid Grid.Row="2"
                     ItemsSource="{Binding FavoriteList}"
                     SelectedItem="{Binding SelectedFavorite, Mode=TwoWay}"
                     AutoGenerateColumns="False"
                     IsReadOnly="True"
                     SelectionMode="Single"
                     SelectionUnit="FullRow"
                     HeadersVisibility="Column"
                     CanUserAddRows="False"
                     GridLinesVisibility="None"
                     BorderThickness="0"
                     Margin="0,0,0,8">

            <ui:DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                    <Setter Property="TextBlock.TextAlignment" Value="Left"/>
                    <Setter Property="Background" Value="{ui:ThemeResource ControlFillColorSecondaryBrush}"/>
                    <Setter Property="Foreground" Value="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                    <Setter Property="BorderBrush" Value="{ui:ThemeResource ControlStrokeColorDefaultBrush}"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="Padding" Value="8,6,8,6"/>
                </Style>
            </ui:DataGrid.ColumnHeaderStyle>

            <ui:DataGrid.RowStyle>
                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#3050A0FF"/>
                            <Setter Property="BorderBrush" Value="#50A0FF"/>
                            <Setter Property="BorderThickness" Value="2,0,0,0"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#1550A0FF"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ui:DataGrid.RowStyle>

            <ui:DataGrid.Columns>
                <DataGridTextColumn Header="名前"
                                    Binding="{Binding Name}"
                                    Width="*"/>
                <DataGridTextColumn Header="登録日時"
                                    Binding="{Binding CreatedAt, StringFormat=yyyy/MM/dd HH:mm}"
                                    Width="140"/>
            </ui:DataGrid.Columns>
        </ui:DataGrid>
    </Grid>
</UserControl>
